{
  "name": "ai-crawlability-checker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --experimental-strip-types src/cli.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "start:cli": "node --experimental-strip-types src/cli.ts",
    "typecheck": "tsc --noEmit",
