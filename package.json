  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "express": "^5.1.0",
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.3"
  }
}
